# Dominio de Oracle Service Cloud / Fusion CRM (sin https:// y sin ruta)
# Ejemplo: miempresa.fa.us2.oraclecloud.com
OSC_DOMAIN=

# Credenciales para autenticacion Basic
OSC_USERNAME=
OSC_PASSWORD=

# Opcionales
# Numero de llamadas en paralelo al API (metadatos y descargas)
OSC_MAX_WORKERS=5
# Timeout en segundos por llamada HTTP
OSC_TIMEOUT=60
# Reintentos automaticos ante errores transitorios (5xx, 429, red/timeout)
OSC_MAX_RETRIES=4
# Backoff base en segundos (exponencial: 1s, 2s, 4s, 8s... + jitter)
OSC_RETRY_BACKOFF=1.0
# Circuit breaker: fallos transitorios consecutivos que detienen el job
# (servicio caido/mantenimiento). 0 = desactivado
OSC_CIRCUIT_THRESHOLD=10
# Archivo donde se registran SOLO los errores (ademas de la consola)
ERROR_LOG_FILE=errors.log

# GCP (solo si se usa destination=gcp en GetAttachmentBinary)
# Ruta al JSON de la cuenta de servicio. Vacio = credenciales por defecto (ADC)
GCP_SERVICE_ACCOUNT_FILE=C:\\ruta\\cuenta-servicio.json
